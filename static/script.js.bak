// ══════════════════════════════════════
// 行业岗位选择器
// ══════════════════════════════════════

function onIndustryChange(select) {
  var industry = select.value;
  var posSelect = document.getElementById("position-select");
  var jdArea = document.getElementById("jd-input");

  posSelect.innerHTML = '<option value="">-- 请选择岗位 --</option>';
  if (jdArea) jdArea.value = "";

  if (industry && JD_DATA[industry]) {
    var positions = Object.keys(JD_DATA[industry]);
    for (var i = 0; i < positions.length; i++) {
      var opt = document.createElement("option");
      opt.value = positions[i];
      opt.textContent = positions[i];
      posSelect.appendChild(opt);
    }
    posSelect.disabled = false;
  } else {
    posSelect.disabled = true;
  }
}

function onPositionChange(select) {
  var industry = document.getElementById("industry-select").value;
  var position = select.value;
  var jdArea = document.getElementById("jd-input");

  if (industry && position && JD_DATA[industry] && JD_DATA[industry][position]) {
    jdArea.value = "岗位：" + position + "\n行业：" + industry + "\n\n" + JD_DATA[industry][position];
  }
}

// ══════════════════════════════════════
// 简历模板
// ══════════════════════════════════════

function switchResumeMode(mode) {
  var freeMode = document.getElementById("free-mode");
  var templateMode = document.getElementById("template-mode");
  var btnFree = document.getElementById("btn-mode-free");
  var btnTemplate = document.getElementById("btn-mode-template");

  if (mode === "template") {
    freeMode.style.display = "none";
    templateMode.style.display = "block";
    btnFree.classList.remove("active");
    btnTemplate.classList.add("active");
  } else {
    freeMode.style.display = "block";
    templateMode.style.display = "none";
    btnFree.classList.add("active");
    btnTemplate.classList.remove("active");
  }
}

function getResumeText() {
  var freeMode = document.getElementById("free-mode");
  if (freeMode && freeMode.style.display !== "none") {
    return document.getElementById("resume-input").value.trim();
  }

  // 从模板收集
  var name = document.getElementById("t-name").value.trim();
  var phone = document.getElementById("t-phone").value.trim();
  var email = document.getElementById("t-email").value.trim();
  var education = document.getElementById("t-education").value.trim();
  var school = document.getElementById("t-school").value.trim();
  var major = document.getElementById("t-major").value.trim();
  var gradYear = document.getElementById("t-grad-year").value.trim();
  var experience = document.getElementById("t-experience").value.trim();
  var skills = document.getElementById("t-skills").value.trim();
  var selfIntro = document.getElementById("t-self-intro").value.trim();

  var parts = [];
  if (name) parts.push(name);
  if (phone || email) parts.push("联系方式：" + [phone, email].filter(Boolean).join(" | "));
  parts.push("");
  if (education || school || major) {
    parts.push("教育背景：");
    parts.push([gradYear, school, major, education].filter(Boolean).join(" "));
    parts.push("");
  }
  if (experience) {
    parts.push("工作经历：");
    parts.push(experience);
    parts.push("");
  }
  if (skills) {
    parts.push("技能：" + skills);
    parts.push("");
  }
  if (selfIntro) {
    parts.push("自我评价：");
    parts.push(selfIntro);
  }

  return parts.join("\n");
}

// ══════════════════════════════════════
// 通用工具
// ══════════════════════════════════════

function showError(msg) {
  var toast = document.getElementById("error-toast");
  if (!toast) return;
  toast.textContent = msg;
  toast.classList.add("visible");
  setTimeout(function () { toast.classList.remove("visible"); }, 4000);
}

function getScoreColor(score) {
  if (score >= 80) return "#10B981";
  if (score >= 60) return "#F59E0B";
  return "#EF4444";
}

function renderScoreRing(containerId, score) {
  var container = document.getElementById(containerId);
  if (!container) return;
  var color = getScoreColor(score);
  var c = 2 * Math.PI * 54;
  var offset = c - (score / 100) * c;
  container.innerHTML =
    '<div class="score-ring"><svg viewBox="0 0 128 128"><circle class="bg-circle" cx="64" cy="64" r="54"/><circle class="score-circle" cx="64" cy="64" r="54" stroke="' + color + '" stroke-dasharray="' + c + '" stroke-dashoffset="' + c + '"/></svg><div class="score-value" style="color:' + color + '">' + score + '</div></div><div class="score-label">综合评分</div>';
  requestAnimationFrame(function () {
    var circle = container.querySelector(".score-circle");
    if (circle) circle.style.strokeDashoffset = offset;
  });
}

function renderDimensions(containerId, dimensions) {
  var container = document.getElementById(containerId);
  if (!container || !dimensions || !dimensions.length) return;
  var html = "<h3>维度评分</h3>";
  for (var i = 0; i < dimensions.length; i++) {
    var d = dimensions[i];
    var pct = d.score * 10;
    var color = getScoreColor(pct);
    html += '<div class="dim-item"><div class="dim-header"><span class="dim-name">' + d.name + '</span><span class="dim-score" style="color:' + color + '">' + d.score + '/10</span></div><div class="dim-bar"><div class="dim-bar-fill" data-width="' + pct + '%" style="background:' + color + '"></div></div><div class="dim-comment">' + d.comment + '</div></div>';
  }
  container.innerHTML = html;
  requestAnimationFrame(function () {
    var fills = container.querySelectorAll(".dim-bar-fill");
    for (var j = 0; j < fills.length; j++) fills[j].style.width = fills[j].getAttribute("data-width");
  });
}

function renderList(containerId, title, items, iconClass, listClass) {
  var container = document.getElementById(containerId);
  if (!container || !items || !items.length) { if (container) container.style.display = "none"; return; }
  var html = '<h3><span class="icon ' + iconClass + '"></span>' + title + '</h3><ul class="info-list ' + listClass + '">';
  for (var i = 0; i < items.length; i++) html += "<li>" + items[i] + "</li>";
  container.innerHTML = html + "</ul>";
  container.style.display = "block";
}

function renderSummary(containerId, title, text) {
  var container = document.getElementById(containerId);
  if (!container || !text) { if (container) container.style.display = "none"; return; }
  container.innerHTML = "<h3>" + title + "</h3><p>" + text + "</p>";
  container.style.display = "block";
}

// ══════════════════════════════════════
// 简历诊断
// ══════════════════════════════════════

function submitResume() {
  var btn = document.getElementById("submit-btn");
  var resultPanel = document.getElementById("result-panel");
  var text = getResumeText();

  if (!text) { showError("请先输入简历内容"); return; }
  if (text.length < 20) { showError("简历内容过短，请输入更完整的内容"); return; }

  btn.disabled = true;
  btn.innerHTML = '<span class="loading-spinner"></span>AI 分析中，请稍候...';
  resultPanel.classList.remove("visible");

  fetch("/api/analyze-resume", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ resume_text: text }),
  })
    .then(function (res) { return res.json().then(function (data) { if (!res.ok) throw new Error(data.error || "请求失败"); return data; }); })
    .then(function (data) {
      renderScoreRing("score-container", data.overall_score || 0);
      renderDimensions("dimensions-container", data.dimensions);
      renderList("highlights-container", "亮点", data.highlights, "green", "green");
      renderList("issues-container", "待改进", data.issues, "red", "red");
      renderList("suggestions-container", "优化建议", data.suggestions, "blue", "blue");
      renderSummary("summary-container", "AI 改写的个人简介", data.rewritten_summary);
      resultPanel.classList.add("visible");
      resultPanel.scrollIntoView({ behavior: "smooth", block: "start" });
    })
    .catch(function (err) { showError(err.message || "分析失败，请稍后重试"); })
    .finally(function () { btn.disabled = false; btn.innerHTML = "开始诊断"; });
}

// ══════════════════════════════════════
// JD 匹配
// ══════════════════════════════════════

function submitJdMatch() {
  var btn = document.getElementById("submit-btn");
  var resultPanel = document.getElementById("result-panel");
  var resumeText = getResumeText();
  var jdText = document.getElementById("jd-input").value.trim();

  if (!resumeText) { showError("请先输入简历内容"); return; }
  if (!jdText) { showError("请选择岗位或输入职位描述"); return; }

  btn.disabled = true;
  btn.innerHTML = '<span class="loading-spinner"></span>AI 匹配分析中...';
  resultPanel.classList.remove("visible");

  fetch("/api/match-jd", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ resume_text: resumeText, jd_text: jdText }),
  })
    .then(function (res) { return res.json().then(function (data) { if (!res.ok) throw new Error(data.error || "请求失败"); return data; }); })
    .then(function (data) {
      renderScoreRing("score-container", data.match_score || 0);
      renderSubScores("sub-scores-container", data.sub_scores);
      renderKeywords("keywords-container", data.matched_keywords, data.missing_keywords);
      renderList("strengths-container", "匹配优势", data.strengths, "green", "green");
      renderList("gaps-container", "差距分析", data.gaps, "red", "red");
      renderList("suggestions-container", "定制化建议", data.suggestions, "blue", "blue");
      renderSummary("summary-container", "针对该岗位的个人简介", data.tailored_summary);
      resultPanel.classList.add("visible");
      resultPanel.scrollIntoView({ behavior: "smooth", block: "start" });
    })
    .catch(function (err) { showError(err.message || "分析失败，请稍后重试"); })
    .finally(function () { btn.disabled = false; btn.innerHTML = "开始匹配分析"; });
}

function renderSubScores(containerId, subScores) {
  var container = document.getElementById(containerId);
  if (!container || !subScores) return;
  var labels = { skill_match: "技能匹配", experience_match: "经验匹配", education_match: "学历匹配", industry_match: "行业匹配" };
  var html = "";
  var keys = Object.keys(labels);
  for (var i = 0; i < keys.length; i++) {
    var val = subScores[keys[i]] || 0;
    var color = getScoreColor(val);
    html += '<div class="sub-score-item"><div class="sub-score-value" style="color:' + color + '">' + val + '</div><div class="sub-score-label">' + labels[keys[i]] + '</div></div>';
  }
  container.innerHTML = html;
}

function renderKeywords(containerId, matched, missing) {
  var container = document.getElementById(containerId);
  if (!container) return;
  if ((!matched || !matched.length) && (!missing || !missing.length)) { container.style.display = "none"; return; }
  var html = "<h3>关键词匹配</h3>";
  if (matched && matched.length) {
    html += '<div class="keyword-group"><div class="keyword-group-label">已覆盖</div><div class="keyword-tags">';
    for (var i = 0; i < matched.length; i++) html += '<span class="keyword-tag matched">' + matched[i] + '</span>';
    html += "</div></div>";
  }
  if (missing && missing.length) {
    html += '<div class="keyword-group"><div class="keyword-group-label">未覆盖（建议补充）</div><div class="keyword-tags">';
    for (var j = 0; j < missing.length; j++) html += '<span class="keyword-tag missing">' + missing[j] + '</span>';
    html += "</div></div>";
  }
  container.innerHTML = html;
  container.style.display = "block";
}