# ═══ AI 简历诊断系统 - 环境配置 ═══
# 复制此文件为 .env 并填入你的真实 Key
# cp .env.example .env

# AI 提供商 (gemini 或 groq)
AI_PROVIDER=gemini

# Gemini 配置 (免费: https://aistudio.google.com/apikey)
GEMINI_API_KEYS=your_key_1,your_key_2
GEMINI_MODEL=gemini-2.5-flash

# Groq 配置 (备选: https://console.groq.com)
# GROQ_API_KEY=your_groq_key
# GROQ_MODEL=llama-3.3-70b-versatile

# 服务配置
PORT=8000
DEBUG=true
RATE_LIMIT_PER_MINUTE=10
