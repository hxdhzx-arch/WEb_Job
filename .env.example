# ═══════════════════════════════════════
# 简历 AI SaaS — 环境变量配置
# ═══════════════════════════════════════

# ── Gemini API Key（必填）──
# 多个 Key 用逗号分隔，系统会自动轮询
# 免费获取: https://aistudio.google.com/apikey
GEMINI_API_KEYS=your_key_1,your_key_2

# ── Gemini 模型 ──
GEMINI_MODEL=gemini-2.5-flash

# ── 服务配置 ──
PORT=8000
DEBUG=true
RATE_LIMIT_PER_MINUTE=10

# ── 数据库配置 ──
# SQLite (默认，开发用):
DATABASE_URL=sqlite:///data/resume_ai.db
# MySQL (生产):
# DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/resume_ai?charset=utf8mb4
# PostgreSQL (生产):
# DATABASE_URL=postgresql://user:pass@localhost:5432/resume_ai

# ── JWT 鉴权配置 ──
JWT_SECRET_KEY=change-this-to-a-random-secret-string
JWT_ACCESS_TOKEN_EXPIRES=86400
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ── SMTP 邮件配置（验证码发送）──
# 不配置则验证码打印到控制台（开发模式）
#
# QQ 邮箱配置示例:
#   SMTP_HOST=smtp.qq.com
#   SMTP_PORT=465
#   SMTP_USER=your_qq@qq.com
#   SMTP_PASS=你的QQ邮箱授权码（设置→账户→POP3/SMTP→开启→获取授权码）
#   SMTP_FROM=简历AI <your_qq@qq.com>
#
# Gmail 配置示例:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your_email@gmail.com
#   SMTP_PASS=your_app_password（需开启两步验证后生成应用专用密码）
#   SMTP_FROM=Resume AI <your_email@gmail.com>
#
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── 支付配置（预留）──
# Stripe (海外)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# 支付宝 (国内)
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=

# 微信支付 (国内)
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_NOTIFY_URL=

# ── 管理员初始账号 ──
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456

# ── 试用期 (天) ──
TRIAL_DAYS=7
