# ==========================================
# 简历生成器 Pro - 生产环境配置模板
# ==========================================

# 运行环境 (生产环境必须为 production)
FLASK_ENV=production

# 服务端口
PORT=5000

# ----------------- 核心安全 -----------------
# JWT 秘钥（请勿泄漏，必须使用强随机字符串，可使用 python -c "import secrets; print(secrets.token_hex(32))" 生成）
JWT_SECRET_KEY=replace-with-your-strong-secret-key

# 跨域配置（必需，逗号分隔，生产环境严禁使用 *）
ALLOWED_ORIGINS=https://resume.yourdomain.com,https://api.yourdomain.com

# 管理员默认账号凭证（必须修改以防暴力破解）
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# ----------------- 数据库 -----------------
# 强烈建议生产环境使用 MySQL 或 PostgreSQL，避免使用 SQLite
# PostgreSQL: postgresql://user:pass@localhost/dbname
# MySQL: mysql+pymysql://user:pass@localhost/dbname
DATABASE_URL=sqlite:///data/resume_ai.db

# ----------------- 超级大脑配置 -----------------
# Gemini API Key (多个 Key 用逗号分隔，系统将自动轮询)
GEMINI_API_KEYS=AIzaSy...key1...,AIzaSy...key2...
GEMINI_MODEL=gemini-2.5-flash

# ----------------- 邮件服务 (验证码必需) -----------------
# 生产环境若不配置 SMTP，应用核心功能验证码将无法发送，应用会拒绝启动。
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=no-reply@yourdomain.com
SMTP_PASS=your-smtp-auth-code
SMTP_FROM=简历服务中心

# ----------------- 支付配置 (可选) -----------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
