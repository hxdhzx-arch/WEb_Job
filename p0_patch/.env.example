# ═══════════════════════════════════════
# 简历 AI — 环境变量配置
# ═══════════════════════════════════════

# ── Gemini API Key（必填）──
# 多个 Key 用逗号分隔，系统会自动轮询
# 免费获取: https://aistudio.google.com/apikey
GEMINI_API_KEYS=your_key_1,your_key_2

# ── Gemini 模型 ──
GEMINI_MODEL=gemini-2.5-flash

# ── 服务配置 ──
PORT=8000
DEBUG=true
RATE_LIMIT_PER_MINUTE=10

# ── SMTP 邮件配置（验证码发送）──
# 不配置则验证码打印到控制台（开发模式）
#
# QQ 邮箱配置示例:
#   SMTP_HOST=smtp.qq.com
#   SMTP_PORT=465
#   SMTP_USER=your_qq@qq.com
#   SMTP_PASS=你的QQ邮箱授权码（设置→账户→POP3/SMTP→开启→获取授权码）
#   SMTP_FROM=简历AI <your_qq@qq.com>
#
# Gmail 配置示例:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your_email@gmail.com
#   SMTP_PASS=your_app_password（需开启两步验证后生成应用专用密码）
#   SMTP_FROM=Resume AI <your_email@gmail.com>
#
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
